# Required
TMDB_KEY=your_tmdb_api_key

# Optional - Proxy for Streameast (and other provider) requests. When set, the server never connects to Streameast from its own IP; requests go via the worker.
WORKERS_URL=https://your-worker.workers.dev

# Optional - Redis cache
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Supabase (for config overrides from admin panel)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Config endpoint (for Caffeine Flutter app)
# These values are returned by GET /config and override app .env
# Use your API URL - Vercel, AWS, or self-hosted
CAFFEINE_API_URL=https://your-api.vercel.app

# FlixQuest-style scraper (vixsrc, vidsrc, etc.) - defaults to CAFFEINE_API_URL if not set
# Set to separate URL if you run flixquest-scraper as a separate service
FLIXAPI_URL=
CONSUMET_URL=https://api.consumet.org
VIDSRC_API=
OPENSUBTITLES_KEY=

# Config overrides (optional)
LATEST_VERSION=1.7.1
FORCED_UPDATE=false
STREAMING_SERVER_DCVA=asianload
STREAMING_SERVER_ZORO=vidcloud
VIDSRC_SERVER=vidsrcembed
VIDSRCTO_SERVER=vidplay
FETCH_ROUTE=tmDB
TMDB_PROXY=

# Feature flags
ADS_ENABLED=true
OTT_ADS_ENABLED=true
USE_EXTERNAL_SUBTITLES=false
TRENDING_HOLIDAY_SCROLLER=true
ENABLE_STREAM=true
ENABLE_CHROMECAST=true
DISPLAY_VIP_BANNER=true
ENABLE_OTT=true
